# Built application files
*.apk
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
app/release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
# вообще, пожалуй, эти вещи в репозитории по большей части не нужны,
# но некоторые лучше сохранить
#.idea/
.idea/compiler.xml
.idea/deploymentTargetSelector.xml
# здесь установлена кодировка UTF-8 для файлов .properties,
# иначе там нельзя оставлять комментарии на русском
#.idea/encodings.xml
.idea/gradle.xml
.idea/migrations.xml
.idea/misc.xml
.idea/other.xml
.idea/vcs.xml
.idea/workspace.xml



# Keystore files
# Uncomment the following line if you do not want to check your keystore files in.
#*.jks

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md
